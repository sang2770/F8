<diagram name="Onboarding Swimlane">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Header Title -->
        <mxCell id="title" value="PHỤ LỤC: LƯU ĐỒ SWIMLANE ONBOARDING" style="text;strokeColor=none;fillColor=#003399;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1540" height="40" as="geometry" />
        </mxCell>

        <!-- Column Headers -->
        <mxCell id="col1" value="GIAI ĐOẠN" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#003366;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="col2" value="HCNS" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#2D7D32;" vertex="1" parent="1">
