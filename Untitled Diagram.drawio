        <!-- Stop early -->
        <mxCell id="stop_early" value="Xem xét dừng&#10;thử việc sớm" style="rounded=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1300" y="380" width="140" height="60" as="geometry"/>
