          <mxGeometry x="1040" y="115" width="100" height="80" as="geometry" />
        </mxCell>

        <mxCell id="h1" value="Hỗ trợ / Cải thiện" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFE0B2;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1035" y="235" width="110" height="40" as="geometry" />
