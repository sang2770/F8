        </mxCell>
        <mxCell id="col3" value="KTVH" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="col4" value="BAN ISO" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="780" y="60" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="col5" value="TRƯỞNG BỘ PHẬN /&#10;NGƯỜI ĐÀO TẠ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="980" y="60" width="330" height="60" as="geometry" />
        </mxCell>
        <mxCell id="col6" value="NHÂN SỰ MỚI" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d0d0d0;fontStyle=1;fontColor=#006064;" vertex="1" parent="1">
          <mxGeometry x="1310" y="60" width="250" height="60" as="geometry" />
        </mxCell>

        <!-- STAGE 1 -->
        <mxCell id="s1_title" value="1. Chuẩn bị tiếp nhận" style="text;html=1;strokeColor=#d0d0d0;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;spacingLeft=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b1_hcns" value="Chuẩn bị hồ sơ, thông tin tiếp nhận" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#8BC34A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="135" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="b1_ktvh" value="Chuẩn bị tài khoản, thiết bị,&#10;phần mềm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#2196F3;fontSize=11;" vertex="1" parent="1">
