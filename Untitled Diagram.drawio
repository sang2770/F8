<mxfile host="app.diagrams.net">
  <diagram name="Onboarding Process Flowchart">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="&lt;b&gt;BẮT ĐẦU&lt;/b&gt;&#10;&#10;Hoàn thành&#10;tuyển dụng" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;1. Chuẩn bị tiếp nhận&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- HCNS&lt;br&gt;- KTVH&lt;br&gt;- Trưởng bộ phận&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="220" y="190" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;2. Tiếp nhận nhân sự ngày đầu&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- Làm thủ tục nhận việc&lt;br&gt;- Giới thiệu công ty, nội quy, chính sách&lt;br&gt;- Ký cam kết bảo mật ATTT&lt;br&gt;- Ký hợp đồng thử việc&lt;br&gt;- Bàn giao thiết bị, tài sản (thẻ thang máy, văn phòng phẩm,...)&lt;br&gt;- Bàn giao thiết bị, tài khoản&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="450" y="190" width="220" height="170" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;3. Đào tạo hội nhập và ATTT&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- Đào tạo hội nhập (HCNS)&lt;br&gt;- Đào tạo nhận thức ATTT (Ban ISO)&lt;br&gt;- Ký xác nhận hoàn thành đào tạo&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="720" y="190" width="200" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;4. Đào tạo theo lộ trình PB/CD&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- Theo lộ trình đào tạo đã ban hành&lt;br&gt;- Theo dõi tiến độ&lt;br&gt;- Ký xác nhận từng nội dung đào tạo&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="970" y="190" width="220" height="140" as="geometry"/>
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="s5" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;5. Đánh giá tuần 1&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- Đánh giá hòa nhập, tiếp thu, tác phong&lt;br&gt;- Ghi nhận khó khăn, vướng mắc&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="1240" y="190" width="200" height="140" as="geometry"/>
        </mxCell>

        <!-- Decision 1 -->
        <mxCell id="d1" value="Phù hợp?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1490" y="220" width="110" height="80" as="geometry"/>
        </mxCell>

        <!-- Support / Improve -->
        <mxCell id="improve" value="Hỗ trợ / Cải thiện" style="rounded=1;fillColor=#fff2cc;strokeColor=#d79b00;strokeWidth=2;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1475" y="380" width="140" height="60" as="geometry"/>
