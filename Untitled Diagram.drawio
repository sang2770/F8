        <mxCell id="s2" value="2&#10;&#10;Tiếp nhận nhân sự&#10;ngày đầu&#10;---&#10;- Làm thủ tục nhận việc&#10;- Giới thiệu công ty...&#10;- Ký cam kết bảo mật&#10;- Ký HĐ thử việc&#10;- Bàn giao thiết bị, TK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fe;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="1">
