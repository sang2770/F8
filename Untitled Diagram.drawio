        <!-- Step 6 -->
        <mxCell id="s6" value="&lt;div style=&quot;background-color:#1f4e78; color:#ffffff; font-weight:bold; padding:4px; margin-bottom:4px;&quot;&gt;6. Đánh giá giữa kỳ (01 tháng)&lt;/div&gt;&lt;div style=&quot;text-align:left; padding:4px; font-size:11px;&quot;&gt;- Đối chiếu tiến độ đào tạo&lt;br&gt;- Đánh giá năng lực, mức độ phù hợp&lt;br&gt;- Xác định hỗ trợ cần thiết&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1f4e78;strokeWidth=2;fillColor=#ffffff;align=center;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
