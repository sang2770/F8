        <mxCell id="s1" value="1&#10;&#10;Chuẩn bị&#10;tiếp nhận&#10;---&#10;- HCNS&#10;- KTVH&#10;- Trưởng bộ phận" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fe;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="1">
