        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="s5" target="d1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" value="Có" edge="1" parent="1" source="d1" target="s6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" value="Không" edge="1" parent="1" source="d1" target="improve">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" edge="1" parent="1" source="improve" target="s6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e10" edge="1" parent="1" source="s6" target="d2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e11" value="Có" edge="1" parent="1" source="d2" target="s7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e12" value="Không" edge="1" parent="1" source="d2" target="plan">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e13" edge="1" parent="1" source="plan" target="s7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e14" edge="1" parent="1" source="s7" target="d3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e15" value="Có" edge="1" parent="1" source="d3" target="s8">
