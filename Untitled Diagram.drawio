<mxfile host="app.diagrams.net">
  <diagram name="Onboarding Process">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="800">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Header -->
        <mxCell id="title" value="LƯU ĐỒ QUY TRÌNH ONBOARDING" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1;fontColor=#122C6F;" vertex="1" parent="1">
          <mxGeometry x="550" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Start Node -->
        <mxCell id="start" value="BẮT ĐẦU&#10;&#10;&#10;Hoàn thành&#10;tuyển dụng" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="100" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" value="1&#10;&#10;Chuẩn bị&#10;tiếp nhận" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#BBDEFB;fontStyle=1;align=center;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="160" y="80" width="120" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s1_txt" value="- HCNS&#10;- KTVH&#10;- Trưởng bộ phận" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="170" y="240" width="110" height="50" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="2&#10;&#10;Tiếp nhận nhân sự&#10;ngày đầu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#BBDEFB;fontStyle=1;align=center;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="160" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s2_txt" value="- Làm thủ tục nhận việc&#10;- Giới thiệu công ty, nội quy,&#10; chính sách&#10;- Ký cam kết bảo mật ATTT&#10;- Ký hợp đồng thử việc&#10;- Bàn giao thiết bị, tài sản&#10; (thẻ thang máy, văn phòng&#10; phẩm,...)&#10;- Bàn giao thiết bị, tài khoản" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="240" width="150" height="140" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3" value="3&#10;&#10;Đào tạo hội nhập&#10;và ATTT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#BBDEFB;fontStyle=1;align=center;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="140" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s3_txt" value="- Đào tạo hội nhập (HCNS)&#10;- Đào tạo nhận thức ATTT&#10; (Ban ISO)&#10;- Ký xác nhận hoàn thành&#10; đào tạo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="240" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4" value="4&#10;&#10;Đào tạo theo lộ trình&#10;phòng ban/chức danh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#BBDEFB;fontStyle=1;align=center;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="160" height="150" as="geometry" />
        </mxCell>
        <mxCell id="s4_txt" value="- Theo lộ trình đào tạo đã&#10; ban hành&#10;- Theo dõi tiến độ&#10;- Ký xác nhận&#10; từng nội dung đào tạo" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
