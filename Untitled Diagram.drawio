        </mxCell>
        <mxCell id="s5_txt" value="- Đánh giá hòa nhập,&#10; tiếp thu, tác phong&#10;- Ghi nhận khó khăn,&#10; vướng mắc" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
